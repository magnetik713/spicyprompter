<%- include('../partials/header') %>
<div class="page-header">
  <h1>Prompt Categories</h1>
  <% if (paid) { %><a href="/prompts/categories/new" class="btn btn-primary">+ New Category</a><% } %>
</div>
<% if (query.locked) { %>
<div style="background:color-mix(in srgb,var(--accent) 12%,transparent);border:1px solid var(--accent);padding:12px 16px;border-radius:3px;margin-bottom:1rem;font-size:14px">
  &#128274; Category creation is a paid feature. <a href="/prompts/settings" style="color:var(--accent)">Enter your license key in Settings</a> to unlock.
</div>
<% } %>
<p style="color:var(--muted);margin-bottom:1.5rem"><%= categories.length %> categories &mdash; used with <code>node llm_generator.js --category &lt;name&gt;</code></p>
<table class="prompt-table" style="width:100%;border-collapse:collapse">
  <thead>
    <tr>
      <th style="text-align:left;padding:8px 12px;border-bottom:1px solid var(--border)">Name</th>
      <th style="text-align:left;padding:8px 12px;border-bottom:1px solid var(--border)">Label</th>
      <% if (paid) { %><th style="text-align:left;padding:8px 12px;border-bottom:1px solid var(--border)">Emphasis</th><% } %>
      <% if (paid) { %><th style="padding:8px 12px;border-bottom:1px solid var(--border)"></th><% } %>
    </tr>
  </thead>
  <tbody>
  <% categories.forEach(c => { %>
    <tr style="border-bottom:1px solid var(--border)">
      <td style="padding:8px 12px;font-family:monospace;font-size:13px;white-space:nowrap"><code><%= c.name %></code></td>
      <td style="padding:8px 12px;font-size:14px"><%= c.label %></td>
      <% if (paid) { %><td style="padding:8px 12px;font-size:12px;color:var(--muted);max-width:400px"><%= c.emphasis.slice(0,120) %><%= c.emphasis.length > 120 ? '…' : '' %></td><% } %>
      <% if (paid) { %>
      <td style="padding:8px 12px;white-space:nowrap">
        <a href="/prompts/categories/<%= c.id %>/edit" class="btn btn-secondary" style="font-size:12px;padding:4px 8px">Edit</a>
        <form method="POST" action="/prompts/categories/<%= c.id %>/delete" style="display:inline" onsubmit="return confirm('Delete <%= c.name %>?')">
          <button type="submit" class="btn btn-secondary" style="font-size:12px;padding:4px 8px;color:#e55">Delete</button>
        </form>
      </td>
      <% } %>
    </tr>
  <% }) %>
  </tbody>
</table>
<%- include('../partials/footer') %>
