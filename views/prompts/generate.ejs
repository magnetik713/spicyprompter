      <div class="opt-item"><input type="radio" name="facial_expression" id="fe_moaning" value="moaning"><label for="fe_moaning">Moaning / O-face</label></div>
      <div class="opt-item"><input type="radio" name="facial_expression" id="fe_ahegao" value="ahegao"><label for="fe_ahegao">Ahegao</label></div>
      <div class="opt-item"><input type="radio" name="facial_expression" id="fe_eyes_closed" value="eyes_closed"><label for="fe_eyes_closed">Eyes Closed, Lips Parted</label></div>
      <div class="opt-item"><input type="radio" name="facial_expression" id="fe_biting_lip" value="biting_lip"><label for="fe_biting_lip">Biting Lip</label></div>
      <div class="opt-item"><input type="radio" name="facial_expression" id="fe_eye_contact" value="eye_contact"><label for="fe_eye_contact">Direct Eye Contact</label></div>
      <div class="opt-item"><input type="radio" name="facial_expression" id="fe_looking_up" value="looking_up"><label for="fe_looking_up">Looking Up at Camera</label></div>
      <div class="opt-item"><input type="radio" name="facial_expression" id="fe_smirking" value="smirking"><label for="fe_smirking">Smirking</label></div>
      <div class="opt-item"><input type="radio" name="facial_expression" id="fe_shy" value="shy"><label for="fe_shy">Shy / Flushed</label></div>
      <div class="opt-item"><input type="radio" name="facial_expression" id="fe_pleading" value="pleading"><label for="fe_pleading">Desperate / Pleading</label></div>
      <div class="opt-item"><input type="radio" name="facial_expression" id="fe_blissful" value="blissful"><label for="fe_blissful">Blissful / Serene</label></div>
