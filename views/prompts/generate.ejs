  <!-- Act -->
  <div id="cat-pane-act" class="cat-pane">
    <div class="opt-item"><input type="radio" name="act" id="act_none" value=""><label for="act_none" style="color:var(--muted);font-style:italic">None</label></div>
    <div class="opt-item"><input type="radio" name="act" id="act_random" value="random" checked><label for="act_random" style="font-style:italic;color:var(--muted)">Random</label></div>
    <% actCategories.forEach(c => { %>
    <div class="opt-item">
      <input type="radio" name="act" id="act_<%= c.id %>" value="<%= c.name %>">
      <label for="act_<%= c.id %>"><%= c.label.split(' —')[0] %></label>
    </div>
    <% }) %>
  </div>

  <!-- Scene -->
  <div id="cat-pane-scene" class="cat-pane">
    <div class="opt-item"><input type="radio" name="scene" id="scene_none" value=""><label for="scene_none" style="color:var(--muted);font-style:italic">None</label></div>
    <div class="opt-item"><input type="radio" name="scene" id="scene_random" value="random" checked><label for="scene_random" style="font-style:italic;color:var(--muted)">Random</label></div>
    <% sceneCategories.forEach(c => { %>
    <div class="opt-item">
      <input type="radio" name="scene" id="scene_<%= c.id %>" value="<%= c.name %>">
