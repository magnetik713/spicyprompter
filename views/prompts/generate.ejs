      <div class="opt-item"><input type="radio" name="eye_color" id="ec_dark" value="dark"><label for="ec_dark">Dark / Black</label></div>
    </div>
    <div style="width:100%;border-top:1px solid var(--border);margin:6px 0 2px;padding-top:6px;display:flex;flex-wrap:wrap;align-items:center;gap:0">
      <div style="width:100%;font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--dim);font-family:var(--font);margin-bottom:2px">Skin Tone</div>
      <div class="opt-item"><input type="radio" name="skin_tone" id="st_none" value="" checked><label for="st_none" style="color:var(--muted);font-style:italic">Any</label></div>
      <div class="opt-item"><input type="radio" name="skin_tone" id="st_pale" value="pale"><label for="st_pale">Pale / Fair</label></div>
      <div class="opt-item"><input type="radio" name="skin_tone" id="st_tan" value="tan"><label for="st_tan">Tan / Sun-kissed</label></div>
      <div class="opt-item"><input type="radio" name="skin_tone" id="st_olive" value="olive"><label for="st_olive">Olive</label></div>
