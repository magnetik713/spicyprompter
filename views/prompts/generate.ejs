<% if (!paid) { %>
<p style="font-size:11px;color:var(--muted);margin:8px 0 0;font-family:var(--font-mono)">&#128274; Demo: limited selections shown &mdash; <a href="/prompts/settings" style="color:var(--accent)">unlock all with a license</a></p>
<% } %>

<div id="output-box"></div>

<div id="comfy-neg-wrap" style="margin-top:10px;display:none">
  <label style="font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);font-family:var(--font);display:block;margin-bottom:4px">Negative Prompt <span style="font-weight:400;text-transform:none;letter-spacing:0;font-size:10px">(ComfyUI only)</span></label>
  <textarea id="neg-prompt" rows="2" placeholder="e.g. blurry, low quality, watermark" style="width:100%;box-sizing:border-box;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);padding:6px 8px;font-size:12px;color:var(--text);font-family:var(--font-mono);resize:vertical"></textarea>
</div>

<script>
function selectCat(cat, btn) {
  document.querySelectorAll('.cat-tab').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  document.querySelectorAll('.cat-pane').forEach(function(p) { p.classList.remove('active'); });
  document.getElementById('cat-pane-' + cat).classList.add('active');
}

var DEFAULT_VALS = { race:'Any', bodytype:'Any', role:'Random', act:'Random', scene:'Random', theme:'Random', style:'Random', view:'Any' };

function syncTabVals() {
  ['race','role','act','scene','theme','style','view'].forEach(function(cat) {
    var checked = document.querySelector('input[name="' + cat + '"]:checked');
    var hasVal = !!(checked && checked.value !== '');
    var labelEl = checked ? checked.closest('.opt-item').querySelector('label') : null;
    var labelText = labelEl ? (labelEl.firstChild.nodeValue || labelEl.textContent).trim() : DEFAULT_VALS[cat];
    var el = document.getElementById('tabval-' + cat);
    if (el) el.textContent = hasVal ? labelText : DEFAULT_VALS[cat];
    var tab = document.querySelector('[data-cat="' + cat + '"]');
    if (tab) tab.classList.toggle('has-val', hasVal);
  });
  var btChecked = Array.from(document.querySelectorAll('.bt-check:checked'));
  var btEl = document.getElementById('tabval-bodytype');
  var btTab = document.querySelector('[data-cat="bodytype"]');
  if (btChecked.length === 0) {
    if (btEl) btEl.textContent = 'Any';
    if (btTab) btTab.classList.remove('has-val');
  } else if (btChecked.length === 1) {
    var lbl = btChecked[0].closest('.opt-item').querySelector('label');
    if (btEl) btEl.textContent = (lbl.firstChild.nodeValue || lbl.textContent).trim();
    if (btTab) btTab.classList.add('has-val');
  } else {
    if (btEl) btEl.textContent = btChecked.length + ' selected';
    if (btTab) btTab.classList.add('has-val');
  }
}

function clearBodytype() {
  document.querySelectorAll('.bt-check').forEach(function(el) { el.checked = false; });
  syncTabVals();
}

document.addEventListener('change', function(e) {
  if (e.target.type === 'radio' || e.target.classList.contains('bt-check')) {
    syncTabVals();
    if (e.target.name === 'act') checkActWarning();
  }
});

function startGenerate() {
  if (checkActWarning()) return;
  var act   = (document.querySelector('input[name="act"]:checked') || {}).value   || '';
  var scene = (document.querySelector('input[name="scene"]:checked') || {}).value || '';
  var theme = (document.querySelector('input[name="theme"]:checked') || {}).value || '';


  var subject  = buildSubject();
  var race     = (document.querySelector('input[name="race"]:checked') || {}).value      || '';
  var bodytype = Array.from(document.querySelectorAll('.bt-check:checked')).map(function(el){return el.value;}).join(',');
  var role     = (document.querySelector('input[name="role"]:checked') || {}).value      || '';
  var style       = (document.querySelector('input[name="style"]:checked') || {}).value      || '';
  var hair_color         = (document.querySelector('input[name="hair_color"]:checked') || {}).value         || '';
  var facial_expression  = (document.querySelector('input[name="facial_expression"]:checked') || {}).value  || '';
  var eye_color          = (document.querySelector('input[name="eye_color"]:checked') || {}).value           || '';
  var skin_tone          = (document.querySelector('input[name="skin_tone"]:checked') || {}).value           || '';
  var camera_view        = (document.querySelector('input[name="view"]:checked') || {}).value                || '';
  var count    = document.getElementById('count').value;
  var model    = document.getElementById('model').value;

  var box = document.getElementById('output-box');
  var btn = document.getElementById('gen-btn');
  box.innerHTML = '';
  box.style.display = 'block';
  btn.disabled = true;
  btn.textContent = 'Generating…';

  var params = new URLSearchParams({ count: count, model: model });
  var cleanCat = [act, scene, theme].filter(function(v) { return v && v !== 'random'; }).join(',');
  if (cleanCat) params.set('cats', cleanCat);
  if (act   === 'random') params.set('act_random',   '1');
  if (scene === 'random') params.set('scene_random', '1');
  if (theme === 'random') params.set('theme_random', '1');
  if (subject)  params.set('subject',  subject);
  if (race)     params.set('race',     race);
  if (bodytype) params.set('bodytype', bodytype);
  if (role)        params.set('role',        role);
  if (style)       params.set('style',       style);
  if (hair_color)        params.set('hair_color',        hair_color);
  if (facial_expression) params.set('facial_expression', facial_expression);
  if (eye_color)         params.set('eye_color',         eye_color);
  if (skin_tone)         params.set('skin_tone',         skin_tone);
  if (camera_view)       params.set('camera_view',       camera_view);

  var es = new EventSource('/prompts/generate/run?' + params);

  es.onmessage = function(e) {
    var d = JSON.parse(e.data);
    if (d.type === 'start') {
      box.innerHTML += '<span class="line-info">▶ ' + d.args + '</span>\n';
    } else if (d.type === 'line') {
      var t = d.text;
      var cls = t.includes('ok') ? 'line-ok' : t.includes('error') ? 'line-err' : t.includes('skip') || t.includes('retry') ? 'line-skip' : '';
      box.innerHTML += (cls ? '<span class="' + cls + '">' + t + '</span>' : t) + '\n';
      box.scrollTop = box.scrollHeight;
    } else if (d.type === 'err') {
      box.innerHTML += '<span class="line-err">' + d.text + '</span>\n';
      box.scrollTop = box.scrollHeight;
    } else if (d.type === 'limit') {
      box.innerHTML += '<span class="line-err">⚠ ' + d.msg + ' <a href="/prompts/settings" style="color:var(--accent)">Enter license key &rarr;</a></span>\n';
      btn.disabled = false;
      btn.textContent = 'Generate';
      es.close();
    } else if (d.type === 'done') {
      var genCount = parseInt(count);
      box.innerHTML += '\n<span class="line-info">✓ Done (exit ' + d.code + ')</span>\n';
      if (d.code === 0) {
        box.innerHTML += '<button class="row-btn" style="margin-top:8px;font-size:11px" onclick="queueRecent(' + genCount + ')">⚡ Queue last ' + genCount + ' in ComfyUI</button>\n';
      }
      box.scrollTop = box.scrollHeight;
      btn.disabled = false;
      btn.textContent = 'Generate';
      es.close();
    }
  };

  es.onerror = function() {
    box.innerHTML += '<span class="line-err">Connection error</span>\n';
    btn.disabled = false;
    btn.textContent = 'Generate';
    es.close();
  };
}

async function queueRecent(n) {
  var btn = event.target;
  var statusEl = document.getElementById('comfy-status');
  if (!statusEl) {
    statusEl = document.createElement('div');
    statusEl.id = 'comfy-status';
    statusEl.style.cssText = 'margin-top:8px;font-size:11px;color:var(--muted)';
    btn.parentNode.insertBefore(statusEl, btn.nextSibling);
  }
  btn.textContent = 'Queuing…';
  btn.disabled = true;
  var promptIds = [];
  try {
    var r = await fetch('/prompts/api/recent?n=' + n);
    var prompts = await r.json();
    var ok = 0, fail = 0;
    for (var i = 0; i < prompts.length; i++) {
      try {
        var res = await fetch('/prompts/api/comfyui/queue', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ prompt_text: prompts[i].positive, prompt_db_id: prompts[i].id, negative_text: (document.getElementById('neg-prompt').value || '') })
        });
        var d = await res.json();
        if (d.ok) { ok++; promptIds.push({ comfyId: d.prompt_id, dbId: prompts[i].id }); } else fail++;
      } catch(e) { fail++; }
    }
    btn.textContent = '⚡ Queue last ' + n + ' in ComfyUI';
    btn.disabled = false;
    statusEl.textContent = '✓ Queued ' + ok + (fail ? ' (' + fail + ' failed)' : '') + ' — opening library…';
    if (ok > 0) setTimeout(function() { window.location.href = '/prompts'; }, 1200);
  } catch(e) {
    btn.textContent = '⚡ Queue last ' + n + ' in ComfyUI';
    btn.disabled = false;
    statusEl.textContent = '✗ Error: ' + e.message;
  }
}

async function pollQueueStatus(jobs, statusEl) {
  var done = 0, total = jobs.length;
  var imgEl = document.getElementById('comfy-preview');
  if (!imgEl) {
    imgEl = document.createElement('img');
    imgEl.id = 'comfy-preview';
    imgEl.style.cssText = 'display:none;max-width:100%;margin-top:8px;border-radius:var(--radius)';
    statusEl.parentNode.insertBefore(imgEl, statusEl.nextSibling);
  }
  var pending = jobs.slice();
  async function tick() {
    if (!pending.length) { statusEl.textContent = '✓ All ' + total + ' done'; return; }
    var stillPending = [];
    for (var j = 0; j < pending.length; j++) {
      try {
        var sr = await fetch('/prompts/api/comfyui/status?id=' + encodeURIComponent(pending[j].comfyId));
        var s = await sr.json();
        if (s.status === 'done' && s.filename) {
          done++;
          statusEl.textContent = done + '/' + total + ' done';
          try {
            var fr = await fetch('/prompts/api/comfyui/fetch-image', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ prompt_db_id: pending[j].dbId, filename: s.filename })
            });
            var fd = await fr.json();
            if (fd.image_path) { imgEl.src = '/prompts/' + fd.image_path; imgEl.style.display = 'block'; }
          } catch(e) {}
        } else { stillPending.push(pending[j]); }
      } catch(e) { stillPending.push(pending[j]); }
    }
    pending = stillPending;
    if (pending.length) setTimeout(tick, 3000); else statusEl.textContent = '✓ All ' + total + ' done';
  }
  setTimeout(tick, 3000);
}

function buildSubject() {
  var w = Math.max(0, Math.min(6, parseInt(document.getElementById('subj-w').value) || 0));
  var m = Math.max(0, Math.min(6, parseInt(document.getElementById('subj-m').value) || 0));
  var nums = ['','one','two','three','four','five','six'];
  var women = w === 0 ? '' : w === 1 ? 'woman' : nums[w] + ' women';
  var men   = m === 0 ? '' : m === 1 ? 'man'   : nums[m] + ' men';
  if (w && m) return (w === 1 ? 'a woman' : women) + ' and ' + (m === 1 ? 'a man' : men);
  return women || men || '';
}

function previewSubj() {
  var el = document.getElementById('subj-preview');
  if (el) { var s = buildSubject(); el.textContent = s ? '"' + s + '"' : ''; }
  checkActWarning();
  checkBodyTypeWarning();
}

var SOLO_ACTS  = { joi:1, squirting:1, fingering:1, masturbation:1, posing:1, spread:1, stripping:1, edging:1, shower:1 };
var GROUP_ACTS = { bukakke:1, dp:1 };

function checkActWarning() {
  var w = Math.max(0, parseInt((document.getElementById('subj-w') || {}).value) || 0);
  var m = Math.max(0, parseInt((document.getElementById('subj-m') || {}).value) || 0);
  var total = w + m;
  var actEl = document.querySelector('input[name="act"]:checked');
  var act = actEl ? actEl.value : '';
  var box = document.getElementById('act-warning');
  var genBtn = document.getElementById('gen-btn');
  function clear() { if (box) { box.style.display = 'none'; box.classList.remove('blocked','warn'); } if (genBtn) genBtn.disabled = false; return false; }
  function block(msg) {
    if (box) { box.textContent = '\u2717 ' + msg; box.style.display = 'block'; box.classList.remove('warn'); box.classList.add('blocked'); }
    if (genBtn) genBtn.disabled = true;
    return true;
  }
  function warn(msg) {
    if (box) { box.textContent = '\u26a0 ' + msg; box.style.display = 'block'; box.classList.remove('blocked'); box.classList.add('warn'); }
    if (genBtn) genBtn.disabled = false;
    return false;
  }
  if (!box || !act || act === 'random') return clear();
  if (SOLO_ACTS[act]) return clear();
  if (GROUP_ACTS[act] && total < 3) return block('"' + act + '" requires 3+ people — add more subjects or choose a different act.');
  if (!GROUP_ACTS[act] && total < 2) return warn('"' + act + '" requires a partner — the LLM will adapt for solo, but results may vary.');
  return clear();
}

var BT_CONFLICT_GROUPS = [
  ['busty','flat_chested'],
  ['slim','bbw','chubby','plus_size','thick'],
  ['amazon','petite','short_stack'],
  ['petite_teen','mature','milf'],
];

function checkBodyTypeWarning() {
  var selected = Array.from(document.querySelectorAll('.bt-check:checked')).map(function(el){return el.value;});
  var box = document.getElementById('bt-warning');
  var w = Math.max(0, parseInt((document.getElementById('subj-w')||{}).value)||0);
  if (!box || selected.length < 2) { if (box) box.style.display='none'; return; }
  for (var g = 0; g < BT_CONFLICT_GROUPS.length; g++) {
    var hits = selected.filter(function(s){ return BT_CONFLICT_GROUPS[g].indexOf(s) !== -1; });
    if (hits.length > 1) {
      if (w >= hits.length) {
        box.textContent = '\u2139 ' + hits.join(' + ') + ' will be distributed across the ' + w + ' women.';
        box.className = 'info'; box.style.display = 'block';
      } else {
        box.textContent = '\u26a0 Conflicting body types: ' + hits.join(' + ') + ' — add more women or remove one.';
        box.className = ''; box.style.display = 'block';
      }
      return;
    }
  }
  box.style.display = 'none';
}

document.addEventListener('DOMContentLoaded', function() {
  previewSubj();
  syncTabVals();
  document.getElementById('cat-pane-bodytype').addEventListener('change', checkBodyTypeWarning);
});
</script>
