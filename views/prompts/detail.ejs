<%- include('../partials/header') %>
<div class="breadcrumb"><a href="/prompts">Library</a> &rsaquo; <%= prompt.name %></div>
<div class="page-header">
  <h1><%= prompt.name %></h1>
  <div style="display:flex;gap:8px;align-items:center">
    <% if (!prompt.starred) { %>
    <a href="/prompts/<%= prompt.id %>/edit" class="btn btn-secondary">Edit</a>
    <% } %>
    <% if (prompt.image_path) { %>
    <a href="/prompts/<%= prompt.image_path %>" download class="btn btn-secondary">Download</a>
    <% } %>
    <% if (paid && prompt.positive && !prompt.starred) { %>
    <button id="regen-btn" class="btn btn-secondary" onclick="regenPrompt()">&#x21BA; Regenerate</button>
    <% } %>
    <% if (!prompt.starred) { %>
    <form action="/prompts/<%= prompt.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this prompt?')">
      <button type="submit" class="btn btn-danger">Delete</button>
    </form>
    <% } else { %>
    <span style="font-size:12px;color:#d4a853">&#9733; Locked</span>
    <% } %>
  </div>
</div>
<div class="detail-layout">
  <div class="detail-hero">
    <% if (prompt.image_path) { %>
      <a href="/prompts/<%= prompt.image_path %>" download style="display:block;line-height:0">
        <img src="/prompts/<%= prompt.image_path %>" alt="<%= prompt.name %>" style="cursor:pointer">
      </a>
    <% } else { %>
      <div class="placeholder-thumb">&#127912;</div>
    <% } %>
    <div class="detail-hero-overlay">
      <ul class="meta-list">
        <% if (prompt.base_model) { %><li><span class="label">Model</span><%= prompt.base_model %></li><% } %>

        <% if (prompt.width && prompt.height) { %><li><span class="label">Size</span><%= prompt.width %> &times; <%= prompt.height %></li><% } %>
        <% if (prompt.steps) { %><li><span class="label">Steps</span><%= prompt.steps %></li><% } %>
        <% if (prompt.guidance) { %><li><span class="label">Guidance</span><%= prompt.guidance %></li><% } %>
        <% if (prompt.cfg_scale) { %><li><span class="label">CFG</span><%= prompt.cfg_scale %></li><% } %>
        <% if (prompt.sampler) { %><li><span class="label">Sampler</span><%= prompt.sampler %></li><% } %>
        <% if (prompt.seed) { %><li><span class="label">Seed</span><%= prompt.seed %></li><% } %>
        <% if (prompt.loras) { %><li><span class="label">LoRAs</span><%= prompt.loras %></li><% } %>
        <% if (prompt.trigger_words) { %><li><span class="label">Trigger Words</span><%= prompt.trigger_words %></li><% } %>
      </ul>
      <% if (prompt.tags) { %>
      <div class="card-tags">
        <% prompt.tags.split(',').forEach(t => { %><span class="tag"><%= t.trim() %></span><% }) %>
      </div>
      <% } %>
    </div>
  </div>
  <div class="detail-main">
    <% if (prompt.positive) { %>
    <div class="section">
      <div class="section-label">
        Positive Prompt
        <span style="display:flex;gap:6px;align-items:center">
          <button class="copy-btn" data-target="positive-text">Copy</button>
          <% if (!prompt.starred) { %><button class="copy-btn" id="save-prompt-btn" onclick="savePrompt()">Save</button><% } %>
        </span>
      </div>
      <textarea class="prompt-box positive" id="positive-text" rows="8" style="resize:vertical;width:100%;background:transparent;font-family:var(--font-mono);font-size:13px;color:inherit;border:none;outline:none;padding:0;display:block"<% if (prompt.starred) { %> readonly<% } %>><%= prompt.positive %></textarea>
    </div>
    <% } %>
    <% if (prompt.negative) { %>
    <div class="section">
      <div class="section-label">
        Negative Prompt
        <button class="copy-btn negative" data-target="negative-text">Copy</button>
      </div>
      <div class="prompt-box negative" id="negative-text"><%= prompt.negative %></div>
    </div>
    <% } %>
    <% if (prompt.notes) { %>
    <div class="section">
      <div class="section-label">Notes</div>
      <div class="prompt-box" style="color:var(--dim);font-style:italic"><%= prompt.notes %></div>
    </div>
    <% } %>
  </div>
</div>

<div id="regen-status" style="display:none;margin-top:10px">
  <div style="font-size:12px;color:var(--muted);font-family:var(--font-mono);margin-bottom:6px" id="regen-status-text"></div>
  <div style="height:4px;background:var(--border);border-radius:2px;overflow:hidden;width:100%">
    <div id="regen-bar" style="height:100%;width:0%;background:var(--accent);border-radius:2px;transition:width 0.4s ease"></div>
  </div>
</div>
<style>
#regen-btn.running { color:#e09a3a; border-color:#e09a3a; }
#regen-btn.done    { color:#6db86d; border-color:#6db86d; }
#regen-btn.err     { color:#c0392b; border-color:#c0392b; }
</style>
<script>
function setProgress(pct, text) {
  document.getElementById('regen-bar').style.width = pct + '%';
  document.getElementById('regen-status-text').textContent = text;
}

async function savePrompt() {
  const btn = document.getElementById('save-prompt-btn');
  const text = document.getElementById('positive-text').value;
  btn.textContent = '…';
  btn.disabled = true;
  try {
    const r = await fetch('/prompts/api/save-positive', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: '<%= prompt.id %>', positive: text })
    });
    const d = await r.json();
    btn.textContent = d.ok ? 'Saved!' : 'Error';
    setTimeout(() => { btn.textContent = 'Save'; btn.disabled = false; }, 1500);
  } catch(e) {
    btn.textContent = 'Error';
    setTimeout(() => { btn.textContent = 'Save'; btn.disabled = false; }, 1500);
  }
}

async function regenPrompt() {
  const btn = document.getElementById('regen-btn');
  const wrap = document.getElementById('regen-status');
  if (!confirm('Regenerate this prompt? Existing image will be replaced.')) return;
  btn.disabled = true;
  btn.classList.remove('running','done','err');
  btn.textContent = '⏳ Queuing…';
  wrap.style.display = 'block';
  setProgress(5, 'Sending to ComfyUI…');
  try {
    const r = await fetch('/prompts/api/comfyui/queue', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt_text: document.getElementById('positive-text').value, prompt_db_id: '<%= prompt.id %>' })
    });
    const d = await r.json();
    if (!d.ok) throw new Error(d.error || 'Queue failed');
    btn.textContent = '#' + d.number;
    btn.classList.add('running');
    setProgress(15, 'Queued as #' + d.number + ' — waiting…');
    pollRegen(d.prompt_id, 0);
  } catch(e) {
    btn.classList.add('err');
    btn.textContent = '✗ Failed';
    setProgress(0, e.message);
    setTimeout(() => { btn.textContent = '↺ Regenerate'; btn.classList.remove('err'); btn.disabled = false; wrap.style.display = 'none'; }, 3000);
  }
}

async function pollRegen(promptId, attempts) {
  if (attempts > 180) { setProgress(0, 'Timed out'); return; }
  await new Promise(r => setTimeout(r, 2000));
  try {
    const r = await fetch('/prompts/api/comfyui/status?id=' + encodeURIComponent(promptId));
    const d = await r.json();
    if (d.status === 'running') {
      var pct = Math.min(85, 20 + attempts * 3);
      document.getElementById('regen-btn').classList.add('running');
      document.getElementById('regen-btn').textContent = '▶';
      setProgress(pct, 'Generating…');
      pollRegen(promptId, attempts + 1);
    } else if (d.status === 'pending') {
      setProgress(15, 'Pending in queue…');
      pollRegen(promptId, attempts + 1);
    } else if (d.status === 'done') {
      setProgress(90, 'Fetching image…');
      const fr = await fetch('/prompts/api/comfyui/fetch-image', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prompt_db_id: '<%= prompt.id %>', filename: d.filename, subfolder: d.subfolder || '', type: d.type || 'output' })
      });
      const fd = await fr.json();
      if (fd.image_url) {
        document.querySelector('.detail-hero img') && (document.querySelector('.detail-hero a img').src = fd.image_url);
        const btn = document.getElementById('regen-btn');
        btn.classList.remove('running'); btn.classList.add('done');
        btn.textContent = '✓';
        setProgress(100, 'Done! Reloading…');
        setTimeout(() => location.reload(), 1000);
      }
    } else if (d.status === 'error') {
      const btn = document.getElementById('regen-btn');
      btn.classList.remove('running'); btn.classList.add('err');
      btn.textContent = '✗';
      setProgress(0, 'Generation failed');
    } else {
      pollRegen(promptId, attempts + 1);
    }
  } catch(e) { pollRegen(promptId, attempts + 1); }
}
</script>
<%- include('../partials/footer') %>
