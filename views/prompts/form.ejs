<%- include('../partials/header') %>
<div class="breadcrumb"><a href="/prompts">Library</a> &rsaquo; <%= title %></div>
<div class="page-header"><h1><%= title %></h1></div>
<form action="<%= action %>" method="<%= method %>" enctype="multipart/form-data">
  <div class="form-grid">
    <div class="form-row">
      <div class="field">
        <label>Name *</label>
        <input type="text" name="name" value="<%= prompt.name || '' %>" required>
      </div>
      <div class="field">
        <label>Base Model</label>
        <input type="text" name="base_model" value="<%= prompt.base_model || '' %>" list="model-list" placeholder="Flux.1, SDXL, Pony...">
        <datalist id="model-list">
          <% models.forEach(m => { %><option value="<%= m %>"><% }) %>
        </datalist>
      </div>
    </div>
    <div class="field">
      <label>Workflow</label>
      <select name="workflow_id">
        <option value="">— none —</option>
        <% workflows.forEach(w => { %>
          <option value="<%= w.id %>" <%= prompt.workflow_id == w.id ? 'selected' : '' %>><%= w.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="field">
      <label>Environment</label>
      <textarea name="environment"><%= prompt.environment || '' %></textarea>
    </div>
    <div class="field">
      <label>Scene</label>
      <textarea name="scene"><%= prompt.scene || '' %></textarea>
    </div>
    <div class="field">
      <label>Positive Prompt *</label>
      <textarea class="large" name="positive" required><%= prompt.positive || '' %></textarea>
    </div>
    <div class="field">
      <label>Negative Prompt</label>
      <textarea class="large" name="negative"><%= prompt.negative || '' %></textarea>
    </div>
    <div class="form-row">
      <div class="field">
        <label>LoRAs</label>
        <input type="text" name="loras" value="<%= prompt.loras || '' %>" placeholder="DetailEnhance:0.8, kenva:1.0">
      </div>
      <div class="field">
        <label>Trigger Words</label>
        <input type="text" name="trigger_words" value="<%= prompt.trigger_words || '' %>" placeholder="masterpiece, best quality">
      </div>
    </div>
    <div class="field">
      <label>Tags (comma-separated)</label>
      <input type="text" name="tags" value="<%= prompt.tags || '' %>" placeholder="cinematic, landscape, portrait">
    </div>
    <div class="field">
      <label>Notes</label>
      <textarea name="notes"><%= prompt.notes || '' %></textarea>
    </div>
    <div class="field">
      <label>Sample Output Image <% if (prompt.image_path) { %>(current: <%= prompt.image_path.split('/').pop() %>)<% } %></label>
      <input type="file" name="image" accept="image/*">
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save</button>
      <a href="/prompts<%= prompt.id ? '/' + prompt.id : '' %>" class="btn btn-secondary">Cancel</a>
    </div>
  </div>
</form>
<%- include('../partials/footer') %>
