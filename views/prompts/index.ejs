<%- include('../partials/header') %>
<style>
  .select-bar { display:none; align-items:center; gap:10px; padding:8px 0; margin-bottom:4px }
  .select-bar.active { display:flex }
  .select-bar span { font-size:13px; color:var(--muted) }
  .export-wrap { position:relative }
  .export-menu { display:none; position:absolute; top:calc(100% + 4px); left:0; background:var(--bg2); border:1px solid var(--border2); border-radius:var(--radius); min-width:80px; z-index:100; overflow:hidden }
  .export-menu.open { display:block }
  .export-menu button { display:block; width:100%; text-align:left; padding:7px 12px; font-size:12px; color:var(--text); background:none; border:none; cursor:pointer; font-family:var(--font) }
  .export-menu button:hover { background:var(--bg3); }

  .prompt-list { display:flex; flex-direction:column; gap:1px; }
  .prompt-row {
    display:flex; align-items:flex-start; gap:12px;
    padding:8px 10px; background:var(--bg2); border-radius:var(--radius);
    border:1px solid var(--border); transition:border-color .12s;
    text-decoration:none; color:var(--text); position:relative;
  }
  .prompt-row:hover { border-color:var(--border2); text-decoration:none; background:var(--bg3); }
  .row-check { display:none; flex-shrink:0; accent-color:var(--accent); cursor:pointer; }
  .select-mode .row-check { display:block; }
  .select-mode .prompt-row.selected { border-color:var(--accent); }
  .row-thumb {
    width:48px; height:48px; flex-shrink:0; border-radius:3px;
    overflow:hidden; background:var(--bg3); display:flex; align-items:center; justify-content:center;
    font-size:18px; color:var(--dim); border:1px solid var(--border);
  }
  .row-thumb img { width:100%; height:100%; object-fit:cover; display:block; }
  .row-body { flex:1; min-width:0; }
  .row-name { font-size:12px; color:var(--text); overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; line-height:1.5; }
  .row-meta { display:flex; flex-direction:column; align-items:flex-end; gap:4px; flex-shrink:0; }
  .row-tags { display:flex; gap:3px; flex-wrap:wrap; justify-content:flex-end; max-width:200px; }
  .row-date { font-size:10px; color:var(--dim); white-space:nowrap; }
  .row-actions { display:flex; gap:4px; flex-shrink:0; align-items:center; }
  .row-btn {
    background:transparent; border:1px solid var(--border); color:var(--muted);
    border-radius:var(--radius); padding:3px 8px; font-size:11px; cursor:pointer;
    font-family:var(--font); transition:all .12s; white-space:nowrap;
  }
  .row-btn:hover { border-color:var(--border2); color:var(--text); }
  .row-btn.star { color:var(--dim); }
  .row-btn.star.on { color:#d4a853; border-color:#d4a853; }
  .row-btn.copy.copied { color:#6db86d; border-color:#6db86d; }
  .row-btn.comfy { color:var(--dim); }
  .row-btn.comfy.queued { color:#6db86d; border-color:#6db86d; }
  .row-btn.comfy.err { color:#c0392b; border-color:#c0392b; }
  .row-btn.comfy.running { color:#e09a3a; border-color:#e09a3a; }
  .controls-bar { display:flex; align-items:center; gap:8px; margin-bottom:12px; flex-wrap:wrap; }
  .sort-btn { padding:4px 12px; border-radius:var(--radius); font-size:12px; background:var(--bg2); color:var(--dim); border:1px solid var(--border); cursor:pointer; text-decoration:none; }
  .sort-btn:hover { color:var(--text); text-decoration:none; }
  .sort-btn.active { color:var(--accent); border-color:var(--accent); }
</style>

<div class="page-header">
  <h1>Prompt Library</h1>
  <% if (!paid) { %>
  <span style="font-size:11px;color:var(--muted);font-family:var(--font-mono)"><%= promptTotal %> / 50 prompts &mdash; <a href="/prompts/settings" style="color:var(--accent)">upgrade for unlimited</a></span>
  <% } %>
  <div style="display:flex;gap:8px">
    <button id="select-toggle" class="btn btn-secondary" onclick="toggleSelect()">Select</button>
    <a href="/prompts/new" class="btn btn-primary">+ New</a>
  </div>
</div>

<div id="select-bar" class="select-bar">
  <span id="sel-count">0 selected</span>
  <button class="btn btn-secondary" onclick="selectAll()">All</button>
  <button class="btn btn-secondary" onclick="selectNone()">None</button>
  <button id="del-btn" class="btn" style="background:#c0392b;color:#fff;border-color:#c0392b" onclick="deleteSelected()" disabled>Delete</button>
  <button id="queue-btn" class="btn" style="background:var(--accent);color:#fff;border-color:var(--accent)" onclick="queueSelected(this)" disabled>&#x26A1; Queue</button>
  <button id="dl-btn" class="btn btn-secondary" onclick="downloadSelected()" disabled>&#x2B07; Download</button>
  <div class="export-wrap">
    <button id="export-btn" class="btn btn-secondary" onclick="toggleExportMenu(event)" disabled>Export ▾</button>
    <div class="export-menu" id="export-menu">
      <button onclick="exportSelected('csv')">CSV</button>
      <button onclick="exportSelected('json')">JSON</button>
      <button onclick="exportSelected('txt')">TXT</button>
    </div>
  </div>
</div>

<form id="batch-form" method="POST" action="/prompts/batch-delete" style="display:none">
  <div id="batch-ids"></div>
</form>

<form method="GET" action="/prompts" class="search-bar">
  <input type="text" name="q" value="<%= q %>" placeholder="Search name, tags, prompt...">
  <button type="submit" class="btn btn-secondary">Search</button>
  <% if (q) { %><a href="/prompts" class="btn btn-secondary">Clear</a><% } %>
</form>

<%
  function catUrl(c) {
    const p = [];
    if (q) p.push('q=' + encodeURIComponent(q));
    selectedTags.forEach(t => p.push('tag=' + encodeURIComponent(t)));
    if (c) p.push('category=' + encodeURIComponent(c));
    return '/prompts' + (p.length ? '?' + p.join('&') : '');
  }
  function tagUrl(tags) {
    const p = [];
    if (q) p.push('q=' + encodeURIComponent(q));
    tags.forEach(t => p.push('tag=' + encodeURIComponent(t)));
    if (selectedCategory) p.push('category=' + encodeURIComponent(selectedCategory));
    return '/prompts' + (p.length ? '?' + p.join('&') : '');
  }
  function pageUrl(pg) {
    const parts = [];
    if (q) parts.push('q=' + encodeURIComponent(q));
    selectedTags.forEach(t => parts.push('tag=' + encodeURIComponent(t)));
    if (selectedCategory) parts.push('category=' + encodeURIComponent(selectedCategory));
    if (pg > 1) parts.push('page=' + pg);
    return '/prompts' + (parts.length ? '?' + parts.join('&') : '');
  }
  function pageRange(cur, total) {
    const pages = new Set([1, total, cur-1, cur, cur+1].filter(p => p >= 1 && p <= total));
    const sorted = [...pages].sort((a,b) => a-b);
    const result = []; let prev = null;
    for (const p of sorted) {
      if (prev !== null && p - prev > 1) result.push('…');
      result.push(p); prev = p;
    }
    return result;
  }
%>

<%
  function sortUrl(s) {
    const p = [];
    if (q) p.push('q=' + encodeURIComponent(q));
    selectedTags.forEach(t => p.push('tag=' + encodeURIComponent(t)));
    if (selectedCategory) p.push('category=' + encodeURIComponent(selectedCategory));
    if (showStarred) p.push('starred=1');
    if (s !== 'newest') p.push('sort=' + s);
    return '/prompts' + (p.length ? '?' + p.join('&') : '');
  }
  function starredUrl(on) {
    const p = [];
    if (q) p.push('q=' + encodeURIComponent(q));
    selectedTags.forEach(t => p.push('tag=' + encodeURIComponent(t)));
    if (selectedCategory) p.push('category=' + encodeURIComponent(selectedCategory));
    if (selectedSort !== 'newest') p.push('sort=' + selectedSort);
    if (on) p.push('starred=1');
    return '/prompts' + (p.length ? '?' + p.join('&') : '');
  }
%>

<% if (!isPaid) { %>
<div style="padding:8px 12px;background:rgba(201,150,62,.06);border:1px solid rgba(201,150,62,.2);border-radius:4px;font-size:12px;color:var(--muted);margin-bottom:10px">
  🔒 Sort, filter, and star features require a <a href="/prompts/settings" style="color:var(--accent)">full license</a>.
</div>
<% } %>
<% if (isPaid) { %>
<div class="controls-bar">
  <a href="<%= sortUrl('newest') %>" class="sort-btn <%= selectedSort==='newest' ? 'active' : '' %>">Newest</a>
  <a href="<%= sortUrl('oldest') %>" class="sort-btn <%= selectedSort==='oldest' ? 'active' : '' %>">Oldest</a>
  <a href="<%= sortUrl('az') %>"     class="sort-btn <%= selectedSort==='az'     ? 'active' : '' %>">A–Z</a>
  <a href="<%= sortUrl('category') %>" class="sort-btn <%= selectedSort==='category' ? 'active' : '' %>">Category</a>
  <span style="margin-left:4px;width:1px;height:20px;background:var(--border);display:inline-block"></span>
  <a href="<%= starredUrl(!showStarred) %>" class="sort-btn <%= showStarred ? 'active' : '' %>">★ Starred</a>
  <% if (categories.length > 0) { %>
  <span style="margin-left:4px;width:1px;height:20px;background:var(--border);display:inline-block"></span>
  <a href="<%= catUrl('') %>" class="sort-btn <%= !selectedCategory ? 'active' : '' %>">All</a>
  <% categories.forEach(c => { %>
    <a href="<%= catUrl(c) %>" class="sort-btn <%= selectedCategory===c ? 'active' : '' %>"><%= c %></a>
  <% }) %>
  <% } %>
</div>
<% } %>

<div class="results-bar">
  <%= total %> prompt<%= total !== 1 ? 's' : '' %><% if (totalPages > 1) { %> &mdash; page <%= page %> of <%= totalPages %><% } %>
</div>

<% if (prompts.length === 0) { %>
  <div class="empty">
    <p>No prompts found. <a href="/prompts/new">Save your first one</a>.</p>
  </div>
<% } else { %>
<div class="prompt-list" id="card-grid">
  <% prompts.forEach(p => { %>
  <div class="prompt-row-wrap" style="display:flex;align-items:center;gap:8px;margin-bottom:1px">
    <input type="checkbox" class="row-check" value="<%= p.id %>" onchange="onCheck(this)">
    <% if (isPaid) { %><div class="row-actions">
      <button class="row-btn star <%= p.starred ? 'on' : '' %>" data-id="<%= p.id %>" onclick="toggleStar(event,this)" title="Star">★</button>
      <button class="row-btn comfy" data-id="<%= p.id %>" data-text="<%- (p.positive||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/\n/g,' ') %>" onclick="queueComfy(event,this)" title="Send to ComfyUI">⚡</button>
      <button class="row-btn copy" data-text="<%- (p.positive||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/\n/g,' ') %>" onclick="copyPrompt(event,this)" title="Copy">Copy</button>
    </div><% } %>
    <a href="/prompts/<%= p.id %>" class="prompt-row" style="flex:1" id="row-<%= p.id %>">
      <div class="row-thumb">
        <% if (p.image_path) { %>
          <img src="/prompts/<%= p.image_path %>" alt="">
        <% } else { %>
          ✦
        <% } %>
      </div>
      <div class="row-body">
        <div class="row-name"><%= p.positive || p.name %></div>
      </div>
      <div class="row-meta">
        <% if (p.tags) { %>
        <div class="row-tags">
          <% p.tags.split(',').slice(0,3).forEach(t => { %>
            <span class="tag"><%= t.trim() %></span>
          <% }) %>
        </div>
        <% } %>
        <div class="row-date"><%= new Date(p.created_at).toLocaleDateString() %></div>
      </div>
    </a>
  </div>
  <% }) %>
</div>

<% if (totalPages > 1) { %>
<div class="pagination">
  <% if (page > 1) { %><a href="<%= pageUrl(page-1) %>" class="page-btn">&laquo;</a><% } %>
  <% pageRange(page, totalPages).forEach(p => { %>
    <% if (p === '…') { %>
      <span class="page-ellipsis">…</span>
    <% } else { %>
      <a href="<%= pageUrl(p) %>" class="page-btn <%= p === page ? 'active' : '' %>"><%= p %></a>
    <% } %>
  <% }) %>
  <% if (page < totalPages) { %><a href="<%= pageUrl(page+1) %>" class="page-btn">&raquo;</a><% } %>
</div>
<% } %>
<% } %>

<script>
let selectMode = false;

function toggleSelect() {
  selectMode = !selectMode;
  document.getElementById('card-grid').classList.toggle('select-mode', selectMode);
  document.getElementById('select-bar').classList.toggle('active', selectMode);
  document.getElementById('select-toggle').textContent = selectMode ? 'Cancel' : 'Select';
  if (!selectMode) selectNone();
}

function onCheck(cb) {
  cb.closest('.prompt-row-wrap').querySelector('.prompt-row').classList.toggle('selected', cb.checked);
  updateCount();
}

function selectAll() {
  document.querySelectorAll('.row-check').forEach(cb => {
    cb.checked = true;
    cb.closest('.prompt-row-wrap').querySelector('.prompt-row').classList.add('selected');
  });
  updateCount();
}

function selectNone() {
  document.querySelectorAll('.row-check').forEach(cb => {
    cb.checked = false;
    cb.closest('.prompt-row-wrap').querySelector('.prompt-row').classList.remove('selected');
  });
  updateCount();
}

function updateCount() {
  const n = document.querySelectorAll('.row-check:checked').length;
  document.getElementById('sel-count').textContent = n + ' selected';
  document.getElementById('del-btn').disabled = n === 0;
  document.getElementById('queue-btn').disabled = n === 0;
  document.getElementById('export-btn').disabled = n === 0;
  document.getElementById('dl-btn').disabled = n === 0;
}


async function downloadSelected() {
  const checks = [...document.querySelectorAll('.row-check:checked')];
  const ids = checks.map(cb => cb.value);
  if (!ids.length) return;
  if (window.showDirectoryPicker) {
    const imgs = checks.map(cb => cb.closest('.prompt-row-wrap').querySelector('img')).filter(Boolean);
    let dir;
    try { dir = await window.showDirectoryPicker({ mode: 'readwrite' }); }
    catch (e) { return; }
    for (const img of imgs) {
      const filename = img.src.split('/').pop();
      try {
        const blob = await fetch(img.src).then(r => r.blob());
        const fh = await dir.getFileHandle(filename, { create: true });
        const w = await fh.createWritable();
        await w.write(blob);
        await w.close();
      } catch(e) { console.warn('skip', filename, e); }
    }
  } else {
    fetch('/prompts/api/download-images', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids })
    }).then(r => r.ok ? r.blob() : r.json().then(e => { throw e; }))
      .then(blob => {
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'spicyprompter-images.zip';
        a.click();
        URL.revokeObjectURL(a.href);
      }).catch(e => alert(e.error || 'No images to download'));
  }
}
function deleteSelected() {
  const ids = [...document.querySelectorAll('.row-check:checked')].map(cb => cb.value);
  if (!ids.length) return;
  if (!confirm('Delete ' + ids.length + ' prompt' + (ids.length !== 1 ? 's' : '') + '?')) return;
  document.getElementById('batch-ids').innerHTML = ids.map(id => '<input type="hidden" name="ids" value="' + id + '">').join('');
  document.getElementById('batch-form').submit();
}

function toggleExportMenu(e) {
  e.stopPropagation();
  document.getElementById('export-menu').classList.toggle('open');
}
document.addEventListener('click', function() {
  var m = document.getElementById('export-menu');
  if (m) m.classList.remove('open');
});

async function exportSelected(format) {
  document.getElementById('export-menu').classList.remove('open');
  const ids = [...document.querySelectorAll('.row-check:checked')].map(cb => cb.value);
  if (!ids.length) return;
  try {
    const r = await fetch('/prompts/api/export', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids, format })
    });
    if (!r.ok) { alert('Export failed'); return; }
    const blob = await r.blob();
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'spicyprompter-export.' + format;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  } catch(e) { alert('Export error: ' + e.message); }
}

async function queueSelected(btn) {
  const checks = [...document.querySelectorAll('.row-check:checked')];
  if (!checks.length) return;
  const orig = btn.textContent;
  btn.disabled = true;
  let ok = 0, fail = 0;
  for (const cb of checks) {
    const wrap = cb.closest('.prompt-row-wrap');
    const comfyBtn = wrap && wrap.querySelector('.row-btn.comfy');
    const text = comfyBtn && comfyBtn.dataset.text;
    if (!text) { fail++; continue; }
    btn.textContent = '⚡ ' + (ok + fail + 1) + '/' + checks.length;
    try {
      const r = await fetch('/prompts/api/comfyui/queue', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prompt_text: text, prompt_db_id: cb.value })
      });
      const d = await r.json();
      if (d.ok) {
        ok++;
        comfyBtn.textContent = '#' + d.number;
        comfyBtn.title = 'Queued as #' + d.number;
        pollComfy(comfyBtn, d.prompt_id, 0);
      } else { fail++; comfyBtn.textContent = '✗'; comfyBtn.classList.add('err'); }
    } catch(e) { fail++; }
  }
  btn.textContent = '✓ ' + ok + ' queued' + (fail ? ' (' + fail + ' failed)' : '');
  setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 4000);
}

async function queueComfy(e, btn) {
  e.preventDefault(); e.stopPropagation();
  var text = btn.dataset.text;
  btn.textContent = '⏳';
  btn.disabled = true;
  try {
    var r = await fetch('/prompts/api/comfyui/queue', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt_text: text, prompt_db_id: btn.dataset.id })
    });
    var d = await r.json();
    if (!d.ok) {
      btn.textContent = '✗';
      btn.classList.add('err');
      btn.title = d.error;
      alert('ComfyUI: ' + d.error);
      setTimeout(function() { btn.textContent = '⚡'; btn.classList.remove('err'); btn.disabled = false; }, 3000);
      return;
    }
    btn.textContent = '#' + d.number;
    btn.title = 'Queued as #' + d.number;
    pollComfy(btn, d.prompt_id, 0);
  } catch(ex) {
    btn.textContent = '✗'; btn.classList.add('err');
    setTimeout(function() { btn.textContent = '⚡'; btn.classList.remove('err'); btn.disabled = false; }, 3000);
  }
}

async function fetchComfyImage(btn, filename) {
  var promptDbId = btn.dataset.id;
  if (!promptDbId) return;
  try {
    var r = await fetch('/prompts/api/comfyui/fetch-image', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt_db_id: promptDbId, filename: filename })
    });
    var d = await r.json();
    if (d.image_url) {
      var wrap = btn.closest('.prompt-row-wrap');
      if (!wrap) return;
      var thumb = wrap.querySelector('.row-thumb');
      if (!thumb) return;
      thumb.innerHTML = '<img src="' + d.image_url + '" style="width:100%;height:100%;object-fit:cover">';
    }
  } catch(e) {}
}

async function pollComfy(btn, promptId, attempts) {
  if (attempts > 180) { btn.textContent = '?'; btn.title = 'Timed out'; btn.disabled = false; return; }
  await new Promise(function(r) { setTimeout(r, 2000); });
  try {
    var r = await fetch('/prompts/api/comfyui/status?id=' + encodeURIComponent(promptId));
    var d = await r.json();
    if (d.status === 'running') {
      btn.textContent = '▶';
      btn.title = 'Generating…';
      btn.classList.add('running');
      pollComfy(btn, promptId, attempts + 1);
    } else if (d.status === 'pending') {
      pollComfy(btn, promptId, attempts + 1);
    } else if (d.status === 'done') {
      btn.textContent = '✓';
      btn.classList.remove('running');
      btn.classList.add('queued');
      btn.title = d.filename || 'Done';
      btn.disabled = false;
      if (d.filename && btn.dataset.id) {
        fetchComfyImage(btn, d.filename);
      }
    } else if (d.status === 'error') {
      btn.textContent = '✗'; btn.classList.remove('running'); btn.classList.add('err');
      btn.title = 'Generation failed';
      btn.disabled = false;
    } else {
      pollComfy(btn, promptId, attempts + 1);
    }
  } catch(ex) {
    pollComfy(btn, promptId, attempts + 1);
  }
}

async function toggleStar(e, btn) {
  e.preventDefault();
  e.stopPropagation();
  const id = btn.dataset.id;
  try {
    const res = await fetch('/prompts/' + id + '/star', { method: 'POST' });
    const data = await res.json();
    btn.classList.toggle('on', data.starred === 1);
  } catch(err) { console.error(err); }
}

function copyPrompt(e, btn) {
  e.preventDefault();
  e.stopPropagation();
  const text = btn.dataset.text;
  function flash() {
    btn.textContent = 'Copied';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
  }
  if (navigator.clipboard && window.isSecureContext) {
    navigator.clipboard.writeText(text).then(flash).catch(() => fallbackCopy(text, flash));
  } else {
    fallbackCopy(text, flash);
  }
}
function fallbackCopy(text, cb) {
  const ta = document.createElement('textarea');
  ta.value = text;
  ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px';
  document.body.appendChild(ta);
  ta.select();
  try { document.execCommand('copy'); cb(); } catch(e) { alert('Copy failed'); }
  document.body.removeChild(ta);
}

// Resume polling for any prompts that were queued but page was navigated away
async function resumePending() {
  try {
    const r = await fetch('/prompts/api/comfyui/pending');
    const rows = await r.json();
    if (!rows.length) return;
    for (const row of rows) {
      var btn = document.querySelector('.row-btn.comfy[data-id="' + row.id + '"]');
      if (!btn) continue;
      try {
        const sr = await fetch('/prompts/api/comfyui/status?id=' + encodeURIComponent(row.comfy_prompt_id));
        const d = await sr.json();
        if (d.status === 'done') {
          btn.textContent = '✓';
          btn.classList.add('queued');
          btn.title = d.filename || 'Done';
          btn.disabled = false;
          if (d.filename) fetchComfyImage(btn, d.filename);
        } else if (d.status === 'error') {
          btn.textContent = '✗'; btn.classList.add('err'); btn.title = 'Failed';
        } else {
          btn.textContent = '⏳'; btn.title = 'Resuming…';
          pollComfy(btn, row.comfy_prompt_id, 0);
        }
      } catch(e) {
        btn.textContent = '⏳';
        pollComfy(btn, row.comfy_prompt_id, 0);
      }
    }
  } catch(e) {}
}

// Restore green checkmark for rows that already have a generated image
document.querySelectorAll('.row-btn.comfy').forEach(function(btn) {
  var wrap = btn.closest('.prompt-row-wrap');
  if (!wrap) return;
  if (wrap.querySelector('.row-thumb img')) {
    btn.textContent = '✓';
    btn.classList.add('queued');
    btn.title = 'Generated';
  }
});
resumePending();
</script>
