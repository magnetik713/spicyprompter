<%- include('../partials/header') %>
<div class="breadcrumb"><a href="/prompts/workflows">Workflows</a> &rsaquo; <%= title %></div>
<div class="page-header"><h1><%= title %></h1></div>
<form action="<%= action %>" method="<%= method %>" enctype="multipart/form-data">
  <div class="form-grid">
    <div class="field">
      <label>Name</label>
      <input type="text" name="name" value="<%= workflow.name || '' %>">
    </div>
    <div class="field">
      <label>Source URL</label>
      <input type="url" name="source_url" value="<%= workflow.source_url || '' %>">
    </div>
    <div class="field">
      <label>Base Model</label>
      <input type="text" name="base_model" value="<%= workflow.base_model || '' %>" list="wf-model-list" placeholder="Flux.1, SDXL, WAN 2.2, Pony...">
      <datalist id="wf-model-list">
        <% models.forEach(m => { %><option value="<%= m %>"><% }) %>
      </datalist>
    </div>
    <div class="form-row">
      <div class="field">
        <label>Sampler</label>
        <select name="sampler">
          <option value="">— none —</option>
          <% samplers.forEach(s => { %>
            <option value="<%= s %>" <%= workflow.sampler === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <div class="field">
        <label>Scheduler</label>
        <select name="scheduler">
          <option value="">— none —</option>
          <% schedulers.forEach(s => { %>
            <option value="<%= s %>" <%= workflow.scheduler === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="field">
        <label>Steps</label>
        <input type="number" name="steps" min="1" max="10000" value="<%= workflow.steps || '' %>">
      </div>
      <div class="field">
        <label>CFG Scale</label>
        <input type="number" name="cfg_scale" min="0" max="100" step="0.1" value="<%= workflow.cfg_scale || '' %>">
      </div>
    </div>
    <div class="field" style="max-width:200px">
      <label>Denoise (img2img)</label>
      <input type="number" name="denoise" min="0" max="1" step="0.01" value="<%= workflow.denoise != null ? workflow.denoise : '' %>">
    </div>
    <div class="field">
      <label>Dependencies (custom nodes, models)</label>
      <textarea name="dependencies"><%= workflow.dependencies || '' %></textarea>
    </div>
    <div class="field">
      <label>Notes</label>
      <textarea name="notes"><%= workflow.notes || '' %></textarea>
    </div>
    <div class="field">
      <label>Workflow JSON File <% if (workflow.workflow_json_path) { %>(current: <%= workflow.workflow_json_path.split('/').pop() %>)<% } %></label>
      <input type="file" name="workflow_json" accept=".json">
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save</button>
      <a href="/prompts/workflows<%= workflow.id ? '/' + workflow.id : '' %>" class="btn btn-secondary">Cancel</a>
    </div>
  </div>
</form>
<%- include('../partials/footer') %>
